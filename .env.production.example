# ==============================
# DreamSense AI - Production ENV
# ==============================

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# JWT Secret (使用随机字符串，越长越安全)
JWT_SECRET=your_strong_random_jwt_secret_here

# PostgreSQL Database (Neon / PlanetScale / Supabase)
# 从 Neon 控制台获取：https://neon.tech
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
